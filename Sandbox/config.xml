<?xml version="1.0" encoding="utf-8"?>
<config>
	<!-- internal render config (do not modify unless you know what you are doing) -->
	<irc_validationlayers type="bool">true</irc_validationlayers>
	<irc_maxbufferdescriptors_bindless type="int">1024</irc_maxbufferdescriptors_bindless>
	<irc_maxtexturedescriptors_bindless type="int">8192</irc_maxtexturedescriptors_bindless>
	<!-- internal render config shaders -->
	<ircs_depthprepass type="string">./shaders/depth</ircs_depthprepass>
	<ircs_postprocessing type="string">./shaders/post_processing</ircs_postprocessing>
	<ircs_main type="string">./shaders/main</ircs_main>
	<ircs_skybox type="string">./shaders/skybox_sphere</ircs_skybox>
	<ircs_particle type="string">./shaders/particle</ircs_particle>
	<ircs_text type="string">./shaders/text</ircs_text>
	<!-- render config-->
	<rc_framesinflight type="int">3</rc_framesinflight>
	<rc_multisamples type="int">1</rc_multisamples>
	<rc_anisotropicsamples type="int">1</rc_anisotropicsamples>
	<rc_renderscale type="double">1.0</rc_renderscale>
	<!-- engine config-->
	<ec_appname type="string">Sandbox</ec_appname>
	<ec_fullscreen type="bool" comment="Overrides ec_windowwidth and ec_windowheight if true">false</ec_fullscreen>
	<ec_windowwidth type="int">1280</ec_windowwidth>
	<ec_windowheight type="int">720</ec_windowheight>
	<ec_refreshrate type="int" comment="-1 for unlimited, 0 for vsync, >0 for fixed">0</ec_refreshrate>
	<!-- path configs -->
	<pc_assetpath type="string">./assets/</pc_assetpath>
	<pc_fontpath type="string">./assets/fonts</pc_fontpath>
</config>	