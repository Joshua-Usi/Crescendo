	<irc_maxbufferdescriptors_bindless type="int">1024</irc_maxbufferdescriptors_bindless>
	<irc_maxtexturedescriptors_bindless type="int">1024</irc_maxtexturedescriptors_bindless>
	<irc_maxobjectcount type="int">8192</irc_maxobjectcount>
	<irc_maxdirectionallightcount type="int">16</irc_maxdirectionallightcount>
	<irc_maxpointlightcount type="int">256</irc_maxpointlightcount>
	<irc_maxspotlightcount type="int">256</irc_maxspotlightcount>
